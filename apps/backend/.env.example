# ─────────────────────────────────────────
# Variáveis de ambiente — Rota Financeira Backend
# Referência: docs/02-TECH-STACK.md (seção 10) e docs/05-SECURITY.md (seção 3)
# NUNCA preencher valores reais neste arquivo. Copiar para .env e preencher localmente.
# ─────────────────────────────────────────

# Banco
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rota_financeira_dev?schema=public
REDIS_URL=redis://localhost:6379

# JWT (app mobile)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# JWT Admin — SECRET DISTINTO do app mobile, nunca reutilizar JWT_ACCESS_SECRET aqui
ADMIN_JWT_SECRET=

# Criptografia
ENCRYPTION_MASTER_KEY=      # AES-256 (32 bytes) para credenciais de plataformas (HKDF por usuário)
FIELD_ENCRYPTION_KEY=       # AES-256 (32 bytes) para campos sensíveis do banco (CPF, e-mail, telefone)
HASH_SECRET=                # Segredo HMAC-SHA256 para hashes de lookup (cpf_hash, email_hash, phone_hash) — docs/05-SECURITY.md seção 3

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Pagar.me
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Sentry
SENTRY_DSN=

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:8081,http://localhost:8082,http://localhost:19006  # Para CORS — separar múltiplas origens com vírgula
