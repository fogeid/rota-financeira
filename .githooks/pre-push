#!/bin/sh
# Bloqueia push direto para main/master — use uma branch feature/* ou fix/* e abra um PR.
protected="main master"
current=$(git rev-parse --abbrev-ref HEAD)
remote_ref=$(cat /dev/stdin | awk '{print $2}')

for branch in $protected; do
  if [ "$current" = "$branch" ] || [ "$remote_ref" = "refs/heads/$branch" ]; then
    echo ""
    echo "  BLOQUEADO: push direto para '$branch' não é permitido."
    echo "  Crie uma branch e abra um PR:"
    echo ""
    echo "    git checkout -b fix/minha-correcao"
    echo "    git push -u origin fix/minha-correcao"
    echo "    gh pr create"
    echo ""
    exit 1
  fi
done
exit 0
